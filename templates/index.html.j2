{# ================================================================
   MACRO: render one stock card
================================================================ #}
{%- macro _render_stock(s) -%}
<div class="stock-card">
  <div class="stock-header">
    <span class="stock-ticker">{{ s.symbol }}</span>
    <span class="signal-badge
      {%- if s.signal == 'BUY' %} badge-buy
      {%- elif s.signal == 'SELL' %} badge-sell
      {%- elif s.signal == 'BUY-watch' %} badge-buy-watch
      {%- else %} badge-sell-watch{% endif %}">
      {{ s.signal }}
    </span>
    <a href="https://finance.yahoo.com/quote/{{ s.ticker }}"
       target="_blank" rel="noopener"
       style="font-size:0.72rem;color:var(--text-dim);">YF ↗</a>
    <a href="https://newsweb.oslobors.no/search?issuer={{ s.symbol }}"
       target="_blank" rel="noopener"
       style="font-size:0.72rem;color:var(--text-dim);">OB ↗</a>
    <span class="stock-price">{{ "%.2f"|format(s.close) }} NOK</span>
  </div>

  <div class="indicators">
    <div class="ind">
      <span class="ind-label">RSI 14</span>
      <span class="ind-value">{{ "%.1f"|format(s.rsi14) }}</span>
    </div>
    <div class="ind">
      <span class="ind-label">ADX 14</span>
      <span class="ind-value">{{ "%.1f"|format(s.adx14) }}</span>
    </div>
    <div class="ind">
      <span class="ind-label">MFI 14</span>
      <span class="ind-value">{{ "%.1f"|format(s.mfi14) }}</span>
    </div>
    <div class="ind">
      <span class="ind-label">MACD hist</span>
      <span class="ind-value">{{ "%.4f"|format(s.macd_hist) }}</span>
    </div>
    <div class="ind">
      <span class="ind-label">vs SMA50</span>
      <span class="ind-value">{{ "%+.1f"|format(s.pct_above_sma50) }}%</span>
    </div>
    <div class="ind">
      <span class="ind-label">Risk</span>
      <span class="ind-value
        {%- if s.risk == 'LOW' %} ind-risk-low
        {%- elif s.risk == 'MODERATE' %} ind-risk-mod
        {%- else %} ind-risk-high{% endif %}">
        {{ s.risk }}
      </span>
    </div>
    <div class="ind">
      <span class="ind-label">Confirmations</span>
      <span class="ind-value">{{ s.primary_count }}/3</span>
    </div>
  </div>

  <div class="risk-row">
    <span>Stop-loss:
      <b>{{ s.stop_loss_pct }}%</b>
      <span class="sl-basis sl-basis-{{ s.stop_loss_basis|lower }}">{{ s.stop_loss_basis }}</span>
    </span>
  </div>

  <div class="news-section">
    <div class="news-label">News — last 14 days</div>

    {% if s.news %}
      {% for item in s.news %}
      <div class="news-item">
        <span class="news-age
          {%- if item.age_label == 'NEW' %} age-new
          {%- elif item.age_label == '14d' %} age-14d
          {%- else %} age-unknown{% endif %}">
          {{ item.age_label if item.age_label else '—' }}
        </span>
        <div class="news-body">
          <div class="news-title">
            <a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.title }}</a>
          </div>
          <div class="news-source">
            {{ item.source }}
            {% if item.published %}
              · <time>{{ item.published.strftime('%d %b %Y') }}</time>
            {% endif %}
          </div>
        </div>
      </div>
      {% endfor %}
    {% else %}
      <p class="no-news">No news found in the last 14 days.</p>
    {% endif %}

    {% if s.news_errors %}
      {% for source_name, err in s.news_errors.items() %}
        <p class="news-error">⚠ {{ source_name }} unavailable: {{ err }}</p>
      {% endfor %}
    {% endif %}

    <div class="news-manual-link">
      Search manually:
      <a href="https://newsweb.oslobors.no/search?issuer={{ s.symbol }}" target="_blank" rel="noopener">Oslo Bors ↗</a>
      &nbsp;·&nbsp;
      <a href="https://e24.no/s/{{ s.symbol }}" target="_blank" rel="noopener">E24 ↗</a>
      &nbsp;·&nbsp;
      <a href="https://www.dn.no/sok?q={{ s.symbol }}" target="_blank" rel="noopener">DN ↗</a>
    </div>
  </div>
</div>
{%- endmacro -%}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Oslo Screener" />
  <meta name="theme-color" content="#1a2332" />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="manifest" href="manifest.json" />
  <link rel="apple-touch-icon" href="icon-192.png" />
  <title>Oslo Screener Dashboard</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0f1923;
      --surface:   #1a2332;
      --surface2:  #223044;
      --border:    #2e4060;
      --text:      #e8edf3;
      --text-dim:  #8fa3bb;
      --buy:       #22c55e;
      --sell:      #ef4444;
      --watch-buy: #86efac;
      --watch-sell:#fca5a5;
      --neutral:   #64748b;
      --accent:    #3b82f6;
      --tag-new:   #22c55e;
      --tag-14d:   #64748b;
      --font:      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    html { font-size: 16px; }
    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
      padding-bottom: env(safe-area-inset-bottom, 16px);
    }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    .container { max-width: 900px; margin: 0 auto; padding: 0 16px; }

    .header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 16px 0 12px;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .header-inner {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 8px;
    }
    .header h1 { font-size: 1.1rem; font-weight: 700; letter-spacing: 0.02em; color: var(--text); }
    .header-meta { font-size: 0.75rem; color: var(--text-dim); line-height: 1.6; }

    .summary-bar { display: flex; flex-wrap: wrap; gap: 8px; padding: 12px 0; }
    .chip {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 10px; border-radius: 20px;
      font-size: 0.8rem; font-weight: 600; border: 1px solid transparent;
    }
    .chip-buy   { background: rgba(34,197,94,.15);  border-color: rgba(34,197,94,.4);  color: var(--buy); }
    .chip-sell  { background: rgba(239,68,68,.15);  border-color: rgba(239,68,68,.4);  color: var(--sell); }
    .chip-wbuy  { background: rgba(134,239,172,.1); border-color: rgba(134,239,172,.3);color: var(--watch-buy); }
    .chip-wsell { background: rgba(252,165,165,.1); border-color: rgba(252,165,165,.3);color: var(--watch-sell); }
    .chip-total { background: rgba(100,116,139,.1); border-color: rgba(100,116,139,.3);color: var(--text-dim); }

    details { margin: 12px 0; }
    summary {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 14px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 8px; cursor: pointer;
      font-size: 0.9rem; font-weight: 600;
      list-style: none; user-select: none;
    }
    summary::-webkit-details-marker { display: none; }
    summary::before {
      content: "▶"; font-size: 0.65rem; color: var(--text-dim);
      transition: transform 0.2s; flex-shrink: 0;
    }
    details[open] summary::before { transform: rotate(90deg); }
    summary .section-count { margin-left: auto; font-size: 0.75rem; color: var(--text-dim); font-weight: 400; }

    .section-buy   summary { border-left: 3px solid var(--buy); }
    .section-sell  summary { border-left: 3px solid var(--sell); }
    .section-wbuy  summary { border-left: 3px solid var(--watch-buy); }
    .section-wsell summary { border-left: 3px solid var(--watch-sell); }
    .section-macro summary { border-left: 3px solid var(--accent); }
    .section-tickers summary { border-left: 3px solid #a78bfa; }

    .stock-list { display: flex; flex-direction: column; gap: 12px; padding: 12px 0 4px; }

    .stock-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 8px; overflow: hidden;
    }
    .stock-header {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 14px 8px; flex-wrap: wrap;
    }
    .stock-ticker { font-size: 1rem; font-weight: 700; letter-spacing: 0.05em; }
    .signal-badge {
      font-size: 0.7rem; font-weight: 700;
      padding: 2px 8px; border-radius: 4px; letter-spacing: 0.05em;
    }
    .badge-buy        { background: rgba(34,197,94,.2);   color: var(--buy); }
    .badge-sell       { background: rgba(239,68,68,.2);   color: var(--sell); }
    .badge-buy-watch  { background: rgba(134,239,172,.15);color: var(--watch-buy); }
    .badge-sell-watch { background: rgba(252,165,165,.15);color: var(--watch-sell); }
    .stock-price { margin-left: auto; font-size: 1rem; font-weight: 600; color: var(--text); }

    .indicators {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      gap: 6px; padding: 4px 14px 12px;
    }
    .ind { background: var(--surface2); border-radius: 6px; padding: 6px 8px; font-size: 0.72rem; }
    .ind-label { color: var(--text-dim); display: block; margin-bottom: 1px; }
    .ind-value { font-weight: 600; font-size: 0.82rem; }
    .ind-risk-low  { color: #86efac; }
    .ind-risk-mod  { color: #fde68a; }
    .ind-risk-high { color: #fca5a5; }

    .risk-row {
      padding: 0 14px 10px; font-size: 0.75rem;
      color: var(--text-dim); display: flex; gap: 16px; flex-wrap: wrap;
    }
    .risk-row span b { color: var(--text); }
    .sl-basis {
      font-size: 0.65rem; font-weight: 700;
      padding: 1px 5px; border-radius: 3px; margin-left: 4px;
      letter-spacing: 0.04em;
    }
    .sl-basis-s\/r { background: rgba(34,197,94,.15); color: #86efac; }
    .sl-basis-atr  { background: rgba(100,116,139,.2); color: var(--text-dim); }

    .news-section { padding: 0 14px 14px; }
    .news-label {
      font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--text-dim); margin-bottom: 6px;
    }
    .news-item {
      display: flex; gap: 8px; padding: 7px 0;
      border-top: 1px solid var(--border); align-items: flex-start;
    }
    .news-age {
      flex-shrink: 0; font-size: 0.65rem; font-weight: 700;
      padding: 2px 5px; border-radius: 3px; margin-top: 2px; letter-spacing: 0.04em;
    }
    .age-new     { background: rgba(34,197,94,.2);  color: var(--tag-new); }
    .age-14d     { background: rgba(100,116,139,.2); color: var(--tag-14d); }
    .age-unknown { background: rgba(100,116,139,.1); color: var(--tag-14d); }

    .news-body { flex: 1; min-width: 0; }
    .news-title { font-size: 0.82rem; color: var(--text); line-height: 1.4; word-break: break-word; }
    .news-source { font-size: 0.7rem; color: var(--text-dim); margin-top: 2px; }
    .news-source time { color: var(--text-dim); }
    .no-news { font-size: 0.78rem; color: var(--text-dim); font-style: italic; padding: 6px 0; }
    .news-error { font-size: 0.72rem; color: #f87171; margin-top: 4px; }
    .news-manual-link { font-size: 0.75rem; margin-top: 6px; }

    .macro-list { padding: 10px 0 4px; }
    .macro-item {
      display: flex; gap: 8px; padding: 8px 14px;
      border-top: 1px solid var(--border); align-items: flex-start;
    }
    .macro-item:first-child { border-top: none; }
    .macro-title { font-size: 0.82rem; color: var(--text); line-height: 1.4; }
    .macro-source { font-size: 0.7rem; color: var(--text-dim); margin-top: 1px; }

    /* Weekly ticker changes */
    .ticker-changes-list { padding: 10px 14px 14px; }
    .ticker-changes-date { font-size: 0.72rem; color: var(--text-dim); margin-bottom: 10px; }
    .ticker-group { margin-bottom: 10px; }
    .ticker-group-label {
      font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; margin-bottom: 6px;
    }
    .ticker-group-label.added   { color: var(--buy); }
    .ticker-group-label.removed { color: var(--sell); }
    .ticker-pills { display: flex; flex-wrap: wrap; gap: 6px; }
    .ticker-pill {
      font-size: 0.75rem; font-weight: 600;
      padding: 3px 9px; border-radius: 4px; letter-spacing: 0.04em;
    }
    .ticker-pill.added   { background: rgba(34,197,94,.15);  color: var(--buy); }
    .ticker-pill.removed { background: rgba(239,68,68,.15);  color: var(--sell); }

    .source-status-section {
      margin: 20px 0 8px; padding: 12px 14px;
      background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
    }
    .source-status-title {
      font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--text-dim); margin-bottom: 8px;
    }
    .source-row { display: flex; align-items: center; gap: 8px; padding: 3px 0; font-size: 0.75rem; }
    .dot-ok   { color: var(--buy);  font-size: 0.65rem; }
    .dot-fail { color: var(--sell); font-size: 0.65rem; }
    .source-detail { color: var(--text-dim); }

    .disclaimer {
      margin: 20px 0 32px; padding: 12px 14px;
      background: var(--surface); border: 1px solid var(--border);
      border-left: 3px solid #f59e0b; border-radius: 8px;
      font-size: 0.72rem; color: var(--text-dim); line-height: 1.6;
    }
    .disclaimer strong { color: #fbbf24; }

    .empty-state { padding: 16px 14px; font-size: 0.82rem; color: var(--text-dim); font-style: italic; }

    @media (min-width: 600px) {
      .header h1 { font-size: 1.2rem; }
      .indicators { grid-template-columns: repeat(7, 1fr); }
      .stock-ticker { font-size: 1.1rem; }
    }
  </style>
</head>
<body>

<header class="header">
  <div class="container">
    <div class="header-inner">
      <div>
        <h1>Oslo Screener Dashboard</h1>
        <div class="header-meta">
          {%- set d = data -%}
          {%- if d.screener_date %}
            Screener data: {{ d.screener_date.strftime('%d %B %Y') }}<br>
          {%- endif %}
          Generated: {{ d.generated_at.strftime('%d %b %Y %H:%M') }} UTC
          &nbsp;·&nbsp; Source: {{ d.screener_source }}
        </div>
      </div>
      <div class="summary-bar">
        <span class="chip chip-buy">BUY {{ d.buy|length }}</span>
        <span class="chip chip-sell">SELL {{ d.sell|length }}</span>
        <span class="chip chip-wbuy">BUY-watch {{ d.buy_watch|length }}</span>
        <span class="chip chip-wsell">SELL-watch {{ d.sell_watch|length }}</span>
        <span class="chip chip-total">{{ d.total_screened }} screened</span>
      </div>
    </div>
  </div>
</header>

<main class="container">

  <!-- MACRO NEWS -->
  {% if data.macro_news %}
  <details class="section-macro" open>
    <summary>Macro &amp; Geopolitics <span class="section-count">Reuters · {{ data.macro_news|length }} items</span></summary>
    <div class="macro-list">
      {% for item in data.macro_news %}
      <div class="macro-item">
        <div>
          <div class="macro-title"><a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.title }}</a></div>
          <div class="macro-source">
            {{ item.source }}
            {% if item.published %} · <time>{{ item.published.strftime('%d %b %Y') }}</time>{% endif %}
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </details>
  {% endif %}

  <!-- WEEKLY TICKER CHANGES -->
  {% set added   = data.ticker_changes | selectattr('change_type', 'eq', 'added')   | list %}
  {% set removed = data.ticker_changes | selectattr('change_type', 'eq', 'removed') | list %}
  {% if data.ticker_changes %}
  <details class="section-tickers">
    <summary>
      Weekly Universe Changes
      <span class="section-count">
        +{{ added|length }} new &nbsp;·&nbsp; -{{ removed|length }} removed
        {% if data.ticker_changes_date %} · {{ data.ticker_changes_date.strftime('%d %b %Y') }}{% endif %}
      </span>
    </summary>
    <div class="ticker-changes-list">
      {% if data.ticker_changes_date %}
      <p class="ticker-changes-date">
        Last updated: {{ data.ticker_changes_date.strftime('%A, %d %B %Y') }}
        — changes remain visible until the next Monday validation run.
      </p>
      {% endif %}
      {% if added %}
      <div class="ticker-group">
        <div class="ticker-group-label added">New listings</div>
        <div class="ticker-pills">
          {% for c in added %}
          <span class="ticker-pill added">{{ c.ticker }}</span>
          {% endfor %}
        </div>
      </div>
      {% endif %}
      {% if removed %}
      <div class="ticker-group">
        <div class="ticker-group-label removed">No longer listed</div>
        <div class="ticker-pills">
          {% for c in removed %}
          <span class="ticker-pill removed">{{ c.ticker }}</span>
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </div>
  </details>
  {% endif %}

  <!-- BUY SIGNALS -->
  <details class="section-buy" {% if data.buy %}open{% endif %}>
    <summary>
      BUY signals
      <span class="section-count">{{ data.buy|length }} stock{% if data.buy|length != 1 %}s{% endif %}</span>
    </summary>
    {% if data.buy %}
    <div class="stock-list">{% for s in data.buy %}{{ _render_stock(s) }}{% endfor %}</div>
    {% else %}
    <div class="empty-state">No BUY signals today.</div>
    {% endif %}
  </details>

  <!-- SELL SIGNALS -->
  <details class="section-sell" {% if data.sell %}open{% endif %}>
    <summary>
      SELL signals
      <span class="section-count">{{ data.sell|length }} stock{% if data.sell|length != 1 %}s{% endif %}</span>
    </summary>
    {% if data.sell %}
    <div class="stock-list">{% for s in data.sell %}{{ _render_stock(s) }}{% endfor %}</div>
    {% else %}
    <div class="empty-state">No SELL signals today.</div>
    {% endif %}
  </details>

  <!-- BUY-WATCH -->
  <details class="section-wbuy">
    <summary>
      BUY-watch
      <span class="section-count">
        {{ data.buy_watch|length }} stock{% if data.buy_watch|length != 1 %}s{% endif %}
        — oversold, reversal not yet confirmed
      </span>
    </summary>
    <p style="padding:10px 14px 4px;font-size:0.78rem;color:var(--text-dim);">
      These stocks are in <strong style="color:var(--watch-buy)">oversold territory (RSI ≤ 35)</strong>
      but have not yet confirmed an upward reversal. If they turn up with support from trend indicators
      they may become BUY signals.
    </p>
    {% if data.buy_watch %}
    <div class="stock-list">{% for s in data.buy_watch %}{{ _render_stock(s) }}{% endfor %}</div>
    {% else %}
    <div class="empty-state">No BUY-watch candidates today.</div>
    {% endif %}
  </details>

  <!-- SELL-WATCH -->
  <details class="section-wsell">
    <summary>
      SELL-watch
      <span class="section-count">
        {{ data.sell_watch|length }} stock{% if data.sell_watch|length != 1 %}s{% endif %}
        — overbought, reversal not yet confirmed
      </span>
    </summary>
    <p style="padding:10px 14px 4px;font-size:0.78rem;color:var(--text-dim);">
      These stocks are in <strong style="color:var(--watch-sell)">overbought territory (RSI ≥ 65)</strong>
      but have not yet confirmed a downward reversal. If they turn down with support from trend indicators
      they may become SELL signals.
    </p>
    {% if data.sell_watch %}
    <div class="stock-list">{% for s in data.sell_watch %}{{ _render_stock(s) }}{% endfor %}</div>
    {% else %}
    <div class="empty-state">No SELL-watch candidates today.</div>
    {% endif %}
  </details>

  <!-- SOURCE STATUS -->
  <div class="source-status-section">
    <div class="source-status-title">Data source quality</div>
    {% for src in data.source_statuses %}
    <div class="source-row">
      <span class="{% if src.ok %}dot-ok{% else %}dot-fail{% endif %}">
        {% if src.ok %}●{% else %}✕{% endif %}
      </span>
      <span>{{ src.name }}</span>
      <span class="source-detail">— {{ src.detail }}</span>
    </div>
    {% endfor %}
    <p style="margin-top:8px;font-size:0.7rem;color:var(--text-dim);">
      News is fetched automatically and is not editorially reviewed.
      Always verify information against the primary source.
    </p>
  </div>

  <!-- DISCLAIMER -->
  <div class="disclaimer">
    <strong>Important:</strong> This dashboard is purely a technical analysis tool.
    Signals are based on RSI, MACD, SMA and ADX indicators — they are not investment advice
    and do not account for company fundamentals, tax rules or your personal risk profile.
    Stop-loss levels marked <em>S/R</em> are derived from recent pivot support/resistance;
    levels marked <em>ATR</em> use the ADX-based fallback from the screener.
    Past performance is no guarantee of future results.
    News is fetched automatically from third-party sources — always check the primary source.
  </div>

</main>
</body>
</html>
